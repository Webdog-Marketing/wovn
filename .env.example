# Shopify Storefront API — safe to expose to the browser
NEXT_PUBLIC_SHOPIFY_DOMAIN=your-store.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=your-storefront-access-token

# The Shopify-connected domain that still serves checkout, e.g. shop.wovn.club
# Falls back to NEXT_PUBLIC_SHOPIFY_DOMAIN if not set
NEXT_PUBLIC_SHOPIFY_CHECKOUT_DOMAIN=shop.wovn.club

# Airtable — server-side only, never prefix with NEXT_PUBLIC_
AIRTABLE_API_KEY=your-airtable-personal-access-token
AIRTABLE_BASE_ID=your-base-id

# Resend — sends a notification email for each new enquiry
RESEND_API_KEY=your-resend-api-key
ENQUIRY_NOTIFICATION_EMAIL=your-email@address.com

# Google Tag Manager — houses GA4, Meta Pixel, and Google Ads.
# Only loads after someone accepts cookies in the banner.
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Google Search Console site verification (the "content" value from the
# HTML tag verification method, not the whole meta tag)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-verification-code
